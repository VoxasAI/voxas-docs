{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Voxas Docs",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Get Started",
        "groups": [
          {
            "group": "Introduction",
            "pages": [
              "index",
              "getting-started/install-voxas-desktop",
              "getting-started/sign-in-and-permissions",
              "getting-started/first-session"
            ]
          }
        ]
      },
      {
        "tab": "Use Voxas",
        "groups": [
          {
            "group": "Core workflows",
            "pages": [
              "use-voxas/sessions-and-history",
              "use-voxas/prompts-and-skills"
            ]
          }
        ]
      },
      {
        "tab": "Troubleshooting",
        "groups": [
          {
            "group": "Fix common issues",
            "pages": [
              "troubleshooting/microphone-permissions"
            ]
          }
        ]
      },
      {
        "tab": "Reference",
        "groups": [
          {
            "group": "Quick lookup",
            "pages": [
              "reference/keyboard-shortcuts",
              "templates/user-feature-template"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Voxas Website",
          "href": "https://voxas.ai",
          "icon": "book-open-cover"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "https://voxas.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Download Voxas",
      "href": "https://voxas.ai"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/voxas_ai",
      "discord": "https://discord.com/invite/voxas"
    }
  }
}
